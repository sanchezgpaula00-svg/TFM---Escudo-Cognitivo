{
  "manifest_version": 3,
  "name": "Escudo Cognitivo Paula y Víctor",
  "version": "1.0",
  "description": "Protección TEA contra Ingeniería Social",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://*/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"]
    }
  ]
}
